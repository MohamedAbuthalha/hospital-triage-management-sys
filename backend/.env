# Backend environment variables
# Copy this file to .env and fill in the values.

# MongoDB Atlas connection string (include username/password and options)
MONGO_URI=  mongodb+srv://admin:admin%40atlas@cluster0.7qiaqqu.mongodb.net/?retryWrites=true&w=majority

# JWT secret used for signing auth tokens
JWT_SECRET=replace-with-a-strong-secret

# (Optional) Port for the backend server
PORT=5000

# (Optional) Node environment
NODE_ENV=development

# (Optional) AI assignment feature flags
# Set AI_ASSIGNMENT_ENABLED=true to enable the AI-based auto-assignment
AI_ASSIGNMENT_ENABLED=false
# (Optional) If using NLP service, set its URL
# NLP_SERVICE_URL=http://localhost:3000
# Confidence threshold for AI assignment (0-1)
AI_CONFIDENCE_THRESHOLD=0.75
